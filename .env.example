# Server address and port
HOST=0.0.0.0
PORT=8000

# Logging level (error, warn, info, debug, trace)
LOG_LEVEL=info

# Path to the robot calibration JSON file
CALIBRATION_PATH=../calibration/leader.json

# Default frames per second for continuous updates
DEFAULT_FPS=30

# Serial communication baud rate for the robot
BAUD_RATE=1000000
